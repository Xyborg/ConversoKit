# Copy to .env and fill in. Never commit .env.

# --- MCP Server ---
PORT=3000
NODE_ENV=development

# --- Auth (packages/auth) ---
# Comma-separated API keys accepted by the MCP server. Leave empty to disable auth in dev.
# CONVERSOKIT_API_KEYS=
# JWT_SECRET=                # HS256 shared secret
# JWKS_URI=                  # Remote JWKS URL (Auth0/Clerk/Supabase)
# COOKIE_SECRET=             # Required by Phase 5 OAuth session cookies

# --- Stripe (packages/integrations) ---
# Leave both unset to fall back to MockPaymentProvider (in-memory checkout).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Persistent stores (packages/integrations/supabase) ---
# Set both to enable Supabase-backed stores; otherwise InMemory* is used.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- CRM / lead-gen (Phase 4) ---
# HUBSPOT_API_KEY=

# --- OAuth providers (Phase 5) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
