# Copy to .env and fill in. Never commit .env.

# --- MCP Server ---
PORT=3000

# --- Auth (packages/auth) ---
# Comma-separated API keys accepted by the MCP server. Leave empty to disable auth in dev.
# CONVERSOKIT_API_KEYS=

# --- Integrations (packages/integrations) ---
# Populate the keys you actually use; templates may require subsets of these.
# STRIPE_SECRET_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# HUBSPOT_API_KEY=
# RESEND_API_KEY=
