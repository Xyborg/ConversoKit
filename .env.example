# Copy to .env and fill in. Never commit .env.

# --- MCP Server ---
PORT=3000
NODE_ENV=development

# --- Auth (packages/auth) ---
# Comma-separated API keys accepted by the MCP server. Leave empty to disable auth in dev.
# CONVERSOKIT_API_KEYS=
# JWT_SECRET=                # HS256 shared secret
# JWKS_URI=                  # Remote JWKS URL (Auth0/Clerk/Supabase)
# COOKIE_SECRET=             # Required by Phase 5 OAuth session cookies

# --- Stripe (packages/integrations) ---
# Leave both unset to fall back to MockPaymentProvider (in-memory checkout).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Persistent stores (packages/integrations/supabase) ---
# Set both to enable Supabase-backed stores; otherwise InMemory* is used.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- CRM / lead-gen (Phase 4) ---
# HUBSPOT_API_KEY=

# --- Email (packages/integrations/resend) ---
# Leave unset to fall back to MockEmailProvider (logs to stdout).
# RESEND_API_KEY=

# --- OAuth providers (Phase 5) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT_ID=                # default 'common'
# MS_REDIRECT_URI=
# AUTH0_DOMAIN=                # e.g. your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_REDIRECT_URI=

# --- JWT-verify auth providers (Phase 7.6) ---
# Set CLERK_PUBLISHABLE_KEY OR CLERK_FRONTEND_API to verify Clerk-issued JWTs.
# CLERK_PUBLISHABLE_KEY=
# CLERK_FRONTEND_API=          # e.g. clerk.example.com (override)
# Set SUPABASE_JWT_SECRET to verify Supabase Auth-issued JWTs.
# SUPABASE_JWT_SECRET=
