{
  "name": "example-crm-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Runnable CRM assistant: lead capture, pipeline alerts, KPI insights, and consent.",
  "scripts": {
    "dev": "concurrently -k -n mcp,ui -c blue,magenta \"pnpm dev:mcp\" \"pnpm dev:ui\"",
    "dev:mcp": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:ui": "vite",
    "build": "vite build"
  },
  "dependencies": {
    "@conversokit/bridge": "workspace:*",
    "@conversokit/integrations": "workspace:*",
    "@conversokit/shared": "workspace:*",
    "@conversokit/themes": "workspace:*",
    "@conversokit/widgets": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.0",
    "vite": "^5.0.0"
  }
}
