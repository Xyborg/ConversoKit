{
  "name": "@conversokit/auth",
  "version": "0.1.1",
  "description": "Auth providers (API key, JWT/JWKS, Google/GitHub/Microsoft/Auth0 OAuth, Clerk, Supabase) and Express middleware for ConversoKit ChatGPT Apps.",
  "license": "Apache-2.0",
  "keywords": [
    "oauth",
    "jwt",
    "jwks",
    "express",
    "middleware",
    "conversokit",
    "chatgpt-apps"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xyborg/ConversoKit.git",
    "directory": "packages/auth"
  },
  "homepage": "https://github.com/Xyborg/ConversoKit#readme",
  "bugs": "https://github.com/Xyborg/ConversoKit/issues",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "jose": "^5.2.4"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.0",
    "@types/node": "^20.10.0",
    "express": "^4.18.2",
    "typescript": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
