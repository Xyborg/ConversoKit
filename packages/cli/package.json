{
  "name": "conversokit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI for ConversoKit — scaffold ChatGPT Apps in <30 minutes.",
  "main": "dist/cli.js",
  "bin": {
    "conversokit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json && node ./scripts/postbuild.mjs",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
