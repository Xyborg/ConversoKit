{
  "name": "conversokit",
  "version": "0.1.1",
  "description": "CLI for ConversoKit — scaffold ChatGPT Apps in <30 minutes. Includes `create`, `add`, and `deploy` commands.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xyborg/ConversoKit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Xyborg/ConversoKit#readme",
  "bugs": "https://github.com/Xyborg/ConversoKit/issues",
  "keywords": [
    "chatgpt",
    "openai",
    "apps-sdk",
    "mcp",
    "boilerplate",
    "react",
    "scaffold",
    "cli",
    "conversokit"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/cli.js",
  "bin": {
    "conversokit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json && node ./scripts/postbuild.mjs",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
