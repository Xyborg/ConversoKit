{
  "name": "@conversokit/shared",
  "version": "0.1.2",
  "description": "Shared Zod schemas, TypeScript types, and example fixtures consumed by every other ConversoKit package.",
  "license": "Apache-2.0",
  "keywords": [
    "zod",
    "schemas",
    "types",
    "contracts",
    "conversokit",
    "chatgpt-apps",
    "mcp"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xyborg/ConversoKit.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/Xyborg/ConversoKit#readme",
  "bugs": "https://github.com/Xyborg/ConversoKit/issues",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
