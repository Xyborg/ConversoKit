{
  "name": "@conversokit/templates",
  "version": "0.1.2",
  "description": "App templates (commerce, booking, saas-onboarding, travel, dashboard) declaring tools, widgets, integrations, auth, and consent for ConversoKit.",
  "license": "Apache-2.0",
  "keywords": [
    "scaffolding",
    "templates",
    "chatgpt-apps",
    "mcp",
    "conversokit"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xyborg/ConversoKit.git",
    "directory": "packages/templates"
  },
  "homepage": "https://github.com/Xyborg/ConversoKit#readme",
  "bugs": "https://github.com/Xyborg/ConversoKit/issues",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "echo \"no tests yet\"",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@conversokit/widgets": "workspace:*",
    "@conversokit/shared": "workspace:*",
    "@conversokit/integrations": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.2.0"
  }
}
