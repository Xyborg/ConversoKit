{
  "name": "@conversokit/widgets",
  "version": "0.1.0",
  "description": "19 themed React widgets for ConversoKit (commerce, booking, lead-gen, travel, dashboard, consent) — every widget styled via `--ck-*` CSS variables.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xyborg/ConversoKit.git",
    "directory": "packages/widgets"
  },
  "homepage": "https://github.com/Xyborg/ConversoKit#readme",
  "bugs": "https://github.com/Xyborg/ConversoKit/issues",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@conversokit/shared": "workspace:*",
    "@conversokit/themes": "workspace:*",
    "@hookform/resolvers": "^3.3.4",
    "date-fns": "^3.6.0",
    "react-hook-form": "^7.51.0",
    "zod": "^3.22.2"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.2.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@types/react": "^18.0.28",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@types/react-dom": "^18.0.11",
    "typescript": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
